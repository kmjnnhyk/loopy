{
  // Consumer-side build: models a USER who wrote tools/agents/workflows with
  // loopy. isolatedDeclarations is OFF here (a consumer app doesn't need it) so
  // the .d.ts carries the INFERRED composite types — exactly what we read by
  // hand to judge name-preservation / hover cleanliness / TS2742 at the seam.
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "preserve",
    "moduleResolution": "bundler",
    "rewriteRelativeImportExtensions": false,
    "isolatedDeclarations": false,
    "composite": false,
    "declaration": true,
    "declarationMap": false,
    "outDir": "dist-examples",
    "rootDir": "examples"
  },
  "include": ["examples"],
  "exclude": ["examples/_negative.ts"],
  "references": [{ "path": "./packages/core" }]
}
