{
  "name": "loopy-workspace",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "loopy monorepo - type-safe TS DSL for LLM agents",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "tsc --build",
    "check:negative": "test \"$(tsc -p tsconfig.negative.json 2>&1 | grep -c 'error TS')\" = \"8\"",
    "check": "tsc --build && tsc -p tsconfig.examples.json && bun run check:negative && bun test",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6",
    "@loopyjs/core": "workspace:*",
    "@loopyjs/test": "workspace:*"
  }
}
